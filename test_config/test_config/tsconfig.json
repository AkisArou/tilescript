{
  "extends": "../packages/tsconfig/tsconfig.react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsxImportSource": "@hypreact/sdk",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "composite": false,
    "paths": {
      "@hypreact/sdk/*": ["../packages/sdk/js/src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tsbuild/test-config.tsbuildinfo"
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./**/*.d.ts"]
}
