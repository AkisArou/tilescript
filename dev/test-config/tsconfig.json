{
  "extends": "../packages/tsconfig/tsconfig.react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsxImportSource": "@tilescript/sdk",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "composite": false,
    "paths": {
      "@tilescript/sdk/*": [
        "../packages/sdk/js/src/*"
      ]
    },
    "tsBuildInfoFile": "./node_modules/.tsbuild/test-config.tsbuildinfo"
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.d.ts"
  ]
}
